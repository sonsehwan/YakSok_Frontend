<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="20dp"
    android:layout_marginVertical="8dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="#F0F0F0">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 약 이름 및 삭제 버튼 -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageView
                android:id="@+id/iv_pill_img"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_pill"
                android:background="#F8F9FA" />

            <TextView
                android:id="@+id/tv_pill_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/iv_pill_img"
                android:layout_centerVertical="true"
                android:layout_marginStart="12dp"
                android:text="약 이름"
                android:textColor="@color/black"
                android:textSize="16sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/btn_remove"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                app:tint="#CCCCCC"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true" />
        </RelativeLayout>

        <!-- 처방 일수 설정 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="처방 일수"
            android:textColor="#333333"
            android:textSize="14sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btn_days_minus"
                android:layout_width="48dp"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="-"
                android:textColor="#7C4DFF"
                android:textSize="24sp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/tv_days_value"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/bg_setting_item"
                android:gravity="center"
                android:text="3 일"
                android:textColor="@color/black"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/btn_days_plus"
                android:layout_width="48dp"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="+"
                android:textColor="#7C4DFF"
                android:textSize="24sp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <!-- 1일 투여 횟수 설정 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="1일 투여 횟수"
            android:textColor="#333333"
            android:textSize="14sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btn_freq_minus"
                android:layout_width="48dp"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="-"
                android:textColor="#7C4DFF"
                android:textSize="24sp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/tv_freq_value"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/bg_setting_item"
                android:gravity="center"
                android:text="3 번"
                android:textColor="@color/black"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/btn_freq_plus"
                android:layout_width="48dp"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="+"
                android:textColor="#7C4DFF"
                android:textSize="24sp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <!-- 1회 투약량 설정 (EditText로 변경됨) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="1회 투약량"
            android:textColor="#333333"
            android:textSize="14sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/et_dosage_value"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_setting_item"
            android:gravity="center"
            android:hint="예: 1정(입력은 숫자만.)"
            android:textColorHint="#808080"
            android:inputType="text"
            android:paddingHorizontal="12dp"
            android:textColor="@color/black"
            android:textSize="16sp"
            android:textCursorDrawable="@null" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>