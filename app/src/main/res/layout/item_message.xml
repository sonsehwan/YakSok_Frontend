<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:paddingHorizontal="16dp"
    android:paddingVertical="6dp">

    <!-- 남이 보낸 채팅 (왼쪽 정렬) -->
    <LinearLayout
        android:id="@+id/ll_other_chat"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_gravity="start"
        android:visibility="visible">

        <!-- 보낸 사람 이름 -->
        <TextView
            android:id="@+id/tv_other_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="상대방 이름"
            android:textSize="13sp"
            android:textColor="#555555"
            android:layout_marginBottom="4dp"/>

        <!-- 채팅 내용과 시간 (내용이 왼쪽, 시간이 오른쪽) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            >

            <TextView
                android:id="@+id/tv_other_message"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxWidth="240dp"
                android:paddingHorizontal="14dp"
                android:paddingVertical="10dp"
                android:text="상대방 메시지 내용"
                android:background="@drawable/bg_message_receive"
                android:textColor="#000000"
                android:textSize="15sp"
                android:visibility="gone"/>



            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_message_receive"
                android:visibility="visible">

                <TextView
                    android:id="@+id/tv_yaksok_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxWidth="240dp"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="10dp"
                    android:text="OOO이 약속을 공유하였습니다. \n약속을 확인해 보세요."
                    android:textColor="#000000"
                    android:textSize="15sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_other_yaksok"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="5dp"
                    android:backgroundTint="@color/white"
                    android:textColor="@color/black"
                    android:text="확인하기"
                    android:textSize="17dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_other_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:layout_marginStart="6dp"
                android:text="07:10"
                android:textSize="11sp"
                android:textColor="#888888"/>
        </LinearLayout>
    </LinearLayout>

    <!-- 내가 보낸 채팅 (오른쪽 정렬) -->
    <LinearLayout
        android:id="@+id/ll_my_chat"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_gravity="end"
        android:visibility="gone">

        <!-- 내 이름 -->
        <TextView
            android:id="@+id/tv_my_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="내 이름"
            android:textSize="13sp"
            android:textColor="#555555"
            android:layout_gravity="end"
            android:layout_marginBottom="4dp"/>

        <!-- 시간과 채팅 내용 묶음 (수평 정렬) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_gravity="end">

            <TextView
                android:id="@+id/tv_my_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:layout_marginEnd="6dp"
                android:text="07:10"
                android:textSize="11sp"
                android:textColor="#888888"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_message_send"
                android:visibility="visible">

                <TextView
                    android:id="@+id/tv_my_yaksok_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxWidth="240dp"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="10dp"
                    android:text="OOO이 약속을 공유하였습니다. \n약속을 확인해 보세요."
                    android:textColor="#000000"
                    android:textSize="15sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_my_yaksok"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="5dp"
                    app:backgroundTint="#FFEB3B"
                    android:textColor="@color/black"
                    android:text="확인하기"
                    android:textSize="17dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_my_message"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxWidth="240dp"
                android:background="@drawable/bg_message_send"
                android:paddingHorizontal="14dp"
                android:paddingVertical="10dp"
                android:text="내가 보낸 메시지 내용"
                android:textColor="#000000"
                android:textSize="15sp"
                android:visibility="gone"/>

        </LinearLayout>
    </LinearLayout>
</FrameLayout>