<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/ll_my_text_message"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_gravity="end"
    android:orientation="vertical">

    <TextView
        android:id="@+id/tv_my_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="내 이름"
        android:textSize="13sp"
        android:textColor="#555555"
        android:layout_gravity="end"
        android:layout_marginBottom="4dp"/>

    <!-- 시간과 채팅 내용 묶음 (수평 정렬) -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_gravity="end">

        <TextView
            android:id="@+id/tv_my_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:layout_marginEnd="6dp"
            android:text="07:10"
            android:textSize="11sp"
            android:textColor="#888888"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_message_receive"
            android:visibility="visible">

            <TextView
                android:id="@+id/tv_yaksok_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxWidth="240dp"
                android:paddingHorizontal="14dp"
                android:paddingVertical="10dp"
                android:text="OOO이 약속을 공유하였습니다. \n약속을 확인해 보세요."
                android:textColor="#000000"
                android:textSize="15sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_other_yaksok"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="5dp"
                android:backgroundTint="@color/white"
                android:textColor="@color/black"
                android:text="확인하기"
                android:textSize="17dp" />
        </LinearLayout>

    </LinearLayout>
</LinearLayout>